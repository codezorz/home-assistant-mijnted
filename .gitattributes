# Enforce Unix line endings for all text files by default.
* text=auto eol=lf

# Keep Windows command/script files with CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
